# Base de datos (usar DATABASE_URL en Railway)
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=SGCOT_DB
DB_PASSWORD=pedri1234
DB_PORT=5432

# Pool de conexiones
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000
DB_SSL_REJECT_UNAUTHORIZED=false

# Servidor
PORT=3001
NODE_ENV=development

# Seguridad
# ⚠️ En producción, generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=clave_secreta_institucional_san_cristobal_2026
JWT_EXPIRES_IN=6h

# ⚠️ En producción, usar una contraseña fuerte para PostgreSQL
# DB_PASSWORD=<generar contraseña segura>

# CORS (separar múltiples orígenes con comas)
CORS_ORIGIN=http://localhost:3000