# ============================================
# SGCOT — Variables de Entorno (Producción)
# ============================================
# Copiar a .env y ajustar valores

# Base de datos (Railway asigna DATABASE_URL automáticamente)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_USER=postgres
DB_HOST=localhost
DB_DATABASE=SGCOT_DB
DB_PASSWORD=postgres
DB_PORT=5432

# Pool de conexiones
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=5000
DB_SSL_REJECT_UNAUTHORIZED=true

# Servidor
PORT=3001
NODE_ENV=development

# Seguridad
# Generar JWT_SECRET con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cee2559a79108350dc948f58c7643bce3dbf22377fb8f890ebe7585930ce539c
JWT_EXPIRES_IN=6h

# CORS (separar múltiples orígenes con comas)
CORS_ORIGIN=http://localhost:3000
